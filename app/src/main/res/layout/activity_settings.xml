<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 AnkiStreak"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Настройки виджета"
            android:textSize="14sp"
            android:textColor="@color/white_50"
            android:layout_marginBottom="28dp" />

        <!-- AnkiDroid Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_bg_lost"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/anki_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_permission_denied"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_anki_permission_desc"
                android:textSize="12sp"
                android:textColor="@color/white_70"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Current Streak Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_bg_done"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/current_streak_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_current_streak"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white_70"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/best_streak_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Лучший: 0"
                android:textSize="12sp"
                android:textColor="@color/white_50"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card Goal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_card_goal"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/card_goal_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="10"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/widget_bg_lost"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="20dp" />

        <!-- Notifications Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_notifications"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <Switch
                android:id="@+id/notifications_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- First Reminder Time -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_reminder_time"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <TimePicker
            android:id="@+id/reminder_time_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner"
            android:layout_marginBottom="16dp" />

        <!-- Critical Reminder Time -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_critical_time"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <TimePicker
            android:id="@+id/critical_time_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner"
            android:layout_marginBottom="24dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/settings_save"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/green_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Debug Button -->
        <Button
            android:id="@+id/debug_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Debug Panel"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="@color/grey_primary"
            android:textColor="@color/white_70"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
