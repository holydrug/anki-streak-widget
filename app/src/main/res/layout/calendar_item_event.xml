<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cal_ev_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingEnd="14dp"
    android:paddingStart="0dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp">

    <!-- Color bar -->
    <ImageView
        android:id="@+id/cal_ev_bar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:importantForAccessibility="no" />

    <!-- Time column -->
    <LinearLayout
        android:layout_width="46dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cal_ev_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/cal_event_time"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/cal_ev_time_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/cal_event_time_end"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cal_ev_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/cal_ev_loc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/cal_event_loc"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Relative tag -->
    <TextView
        android:id="@+id/cal_ev_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/calendar_tag_soon_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/cal_tag_soon_text"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="6dp"
        android:visibility="gone" />
</LinearLayout>
