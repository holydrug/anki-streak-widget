<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/calendar_widget_bg"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/cal_date_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="7"
                android:includeFontPadding="false" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/cal_weekday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/cal_header_weekday"
                    android:text="Понедельник"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/cal_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/cal_header_muted"
                    android:text="Апрель 2026" />
            </LinearLayout>

            <TextView
                android:id="@+id/cal_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/calendar_count_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/cal_header_muted"
                android:visibility="gone" />
        </LinearLayout>

        <!-- WEEK STRIP (for empty weeks) -->
        <LinearLayout
            android:id="@+id/cal_week_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <LinearLayout android:id="@+id/cal_ws_0" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_1" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_2" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_3" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_4" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_5" style="@style/CalWeekStripDay" />
            <LinearLayout android:id="@+id/cal_ws_6" style="@style/CalWeekStripDay" />
        </LinearLayout>

        <!-- EMPTY AREA -->
        <LinearLayout
            android:id="@+id/cal_empty_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/cal_empty_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="@string/cal_free_week" />

            <TextView
                android:id="@+id/cal_empty_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/cal_header_muted"
                android:text="@string/cal_no_events"
                android:layout_marginTop="4dp" />

            <!-- Next event card -->
            <LinearLayout
                android:id="@+id/cal_next_ev_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/calendar_next_ev_bg"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/cal_next_ev_bar"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/cal_header_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:text="@string/cal_nearest" />

                    <TextView
                        android:id="@+id/cal_next_ev_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/cal_next_ev_when"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/cal_header_muted"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- EVENT LIST -->
        <ListView
            android:id="@android:id/list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:scrollbars="none"
            android:fadingEdge="vertical"
            android:fadingEdgeLength="32dp"
            android:requiresFadingEdge="vertical"
            android:overScrollMode="never" />

    </LinearLayout>
</FrameLayout>
